-- 1. Bảng Vai trò (Phần của Ngân)
CREATE TABLE roles (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(20) UNIQUE NOT NULL -- ROLE_ADMIN, ROLE_TENANT
);

-- 2. Bảng Người dùng (Phần của Ngân)
CREATE TABLE users (
    id INT PRIMARY KEY AUTO_INCREMENT,
    username VARCHAR(50) UNIQUE NOT NULL,
    password VARCHAR(255), -- Để trống nếu login Google
    full_name VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    phone VARCHAR(15),
    cccd VARCHAR(15) UNIQUE,
    avatar_url VARCHAR(255),
    role_id INT,
    provider VARCHAR(20) DEFAULT 'LOCAL', -- LOCAL hoặc GOOGLE
    status BOOLEAN DEFAULT TRUE,
    FOREIGN KEY (role_id) REFERENCES roles(id)
);

-- 3. Bảng Phòng trọ (Phần của Mạnh)
CREATE TABLE rooms (
    id INT PRIMARY KEY AUTO_INCREMENT,
    room_number VARCHAR(10) UNIQUE NOT NULL,
    price DECIMAL(10, 2) NOT NULL,
    area FLOAT,
    description TEXT,
    status ENUM('EMPTY', 'OCCUPIED', 'MAINTENANCE') DEFAULT 'EMPTY'
);

-- 4. Bảng Hợp đồng (Phần của Minh)
CREATE TABLE contracts (
    id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT, -- Người thuê
    room_id INT,
    start_date DATE NOT NULL,
    end_date DATE NOT NULL,
    deposit DECIMAL(10, 2), -- Tiền cọc
    status ENUM('ACTIVE', 'EXPIRED', 'TERMINATED') DEFAULT 'ACTIVE',
    FOREIGN KEY (user_id) REFERENCES users(id),
    FOREIGN KEY (room_id) REFERENCES rooms(id)
);

-- 5. Bảng Dịch vụ cố định (Phần của Mai/Liễu)
CREATE TABLE services (
    id INT PRIMARY KEY AUTO_INCREMENT,
    service_name VARCHAR(50) NOT NULL, -- Điện, Nước, Wifi, Rác
    unit_price DECIMAL(10, 2) NOT NULL,
    unit VARCHAR(20) -- kWh, m3, tháng
);

-- 6. Bảng Chỉ số điện nước hàng tháng (Phần của Mai)
CREATE TABLE service_usage (
    id INT PRIMARY KEY AUTO_INCREMENT,
    room_id INT,
    service_id INT,
    old_value INT NOT NULL,
    new_value INT NOT NULL,
    month INT NOT NULL,
    year INT NOT NULL,
    FOREIGN KEY (room_id) REFERENCES rooms(id),
    FOREIGN KEY (service_id) REFERENCES services(id)
);

-- 7. Bảng Hóa đơn (Phần của Liễu/Hằng)
CREATE TABLE invoices (
    id INT PRIMARY KEY AUTO_INCREMENT,
    contract_id INT,
    month INT NOT NULL,
    year INT NOT NULL,
    total_amount DECIMAL(10, 2) NOT NULL,
    payment_status ENUM('UNPAID', 'PAID', 'OVERDUE') DEFAULT 'UNPAID',
    payment_date DATETIME,
    due_date DATE,
    FOREIGN KEY (contract_id) REFERENCES contracts(id)
);

-- 8. Bảng Yêu cầu sửa chữa (Phần của Quân)
CREATE TABLE maintenance_requests (
    id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT,
    room_id INT,
    description TEXT NOT NULL,
    image_url VARCHAR(255),
    status ENUM('PENDING', 'PROCESSING', 'DONE') DEFAULT 'PENDING',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id),
    FOREIGN KEY (room_id) REFERENCES rooms(id)
);

-- 9. Bảng Thông báo (Phần của Liêu)
CREATE TABLE notifications (
    id INT PRIMARY KEY AUTO_INCREMENT,
    title VARCHAR(255) NOT NULL,
    content TEXT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
